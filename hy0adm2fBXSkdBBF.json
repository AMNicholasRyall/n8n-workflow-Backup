    {
      "parameters": {
        "jsCode": "const clinicProducts = $('ClinicProducts1').all();\nconst zenotiSplitout = $('ZenotiSplitout').all();\n\nconst allowedProductNames = new Set(\n  clinicProducts\n    .map(item => item.json.ProductName?.trim().toLowerCase())\n    .filter(Boolean)\n);\n\nconst filteredZenotiItems = zenotiSplitout.filter(item => {\n  const productName = item.json.product_name?.trim().toLowerCase();\n  return allowedProductNames.has(productName);\n});\n\nreturn filteredZenotiItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
