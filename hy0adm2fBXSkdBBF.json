    {
      "parameters": {
        "jsCode": "const rows = items.map(item => item.json);\n\nconst htmlTable = `\n<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\" style=\"border-collapse: collapse; font-family: Arial, sans-serif; font-size: 13px;\">\n  <thead>\n    <tr style=\"background-color: #f2f2f2;\">\n      <th>Center Code</th>\n      <th>Center Name</th>\n      <th>Product Code</th>\n      <th>Product Name</th>\n      <th>Category</th>\n      <th>Sub Category</th>\n      <th>Store Qty</th>\n      <th>Floor Qty</th>\n      <th>Total Qty</th>\n    </tr>\n  </thead>\n  <tbody>\n    ${rows.map(row => `\n      <tr>\n        <td>${row.center_code ?? ''}</td>\n        <td>${row.center_name ?? ''}</td>\n        <td>${row.product_code ?? ''}</td>\n        <td>${row.product_name ?? ''}</td>\n        <td>${row.category ?? ''}</td>\n        <td>${row.sub_category ?? ''}</td>\n        <td style=\"text-align: right;\">${row.store_quantity ?? 0}</td>\n        <td style=\"text-align: right;\">${row.floor_quantity ?? 0}</td>\n        <td style=\"text-align: right;\"><strong>${row.total_quantity ?? 0}</strong></td>\n      </tr>\n    `).join('')}\n  </tbody>\n</table>\n`;\n\nreturn [\n  {\n    json: {\n      htmlTable\n    }\n  }\n];"
      },
