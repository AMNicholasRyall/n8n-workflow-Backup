    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction escapeHtml(value) {\n  if (value === null || value === undefined) return '';\n  return String(value)\n    .replaceAll('&', '&amp;')\n    .replaceAll('<', '&lt;')\n    .replaceAll('>', '&gt;')\n    .replaceAll('\"', '&quot;')\n    .replaceAll(\"'\", '&#039;');\n}\n\nconst rows = items.map(item => item.json);\n\nconst StockMvment = `\n<table style=\"border-collapse: collapse; width: 100%; font-family: Arial, sans-serif; font-size: 13px;\">\n  <thead>\n    <tr style=\"background-color: #f2f2f2;\">\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: left;\">Centre</th>\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: left;\">Product Code</th>\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: left;\">Product Name</th>\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: left;\">Category</th>\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">Starting Store</th>\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">Checkouts</th>\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">Invoice Sales</th>\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">Ending Store</th>\n      <th style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">Ending Floor</th>\n    </tr>\n  </thead>\n  <tbody>\n    ${rows.map(row => `\n      <tr>\n        <td style=\"border: 1px solid #dddddd; padding: 8px;\">${escapeHtml(row.center_name)}</td>\n        <td style=\"border: 1px solid #dddddd; padding: 8px;\">${escapeHtml(row.product_code)}</td>\n        <td style=\"border: 1px solid #dddddd; padding: 8px;\">${escapeHtml(row.product_name)}</td>\n        <td style=\"border: 1px solid #dddddd; padding: 8px;\">${escapeHtml(row.category)}</td>\n        <td style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">${escapeHtml(row.starting_store_quantity)}</td>\n        <td style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">${escapeHtml(row.quantity_checkouts)}</td>\n        <td style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">${escapeHtml(row.quantity_outflow_invoice_sales)}</td>\n        <td style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">${escapeHtml(row.ending_store)}</td>\n        <td style=\"border: 1px solid #dddddd; padding: 8px; text-align: right;\">${escapeHtml(row.ending_floor)}</td>\n      </tr>\n    `).join('')}\n  </tbody>\n</table>\n`;\n\nreturn [\n  {\n    json: {\n      StockMvment\n    }\n  }\n];"
      },
