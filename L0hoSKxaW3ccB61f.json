      {
        "parameters": {
          "jsCode": "// n8n Code node\n// Email Cleanup\n\nconst input = $json;\n\n// -----------------------------\n// Email basics\n// -----------------------------\nconst emailId = input.id || null;\n\nconst html =\n  input.body?.content ||\n  $input.first().json.body?.content ||\n  \"\";\n\n// Pull clinic from first recipient email address.\n// Example: AUC.pharmacy@ashleyandmartin.com.au -> AUC\nconst toAddress =\n  input.toRecipients?.[0]?.emailAddress?.address ||\n  $input.first().json.toRecipients?.[0]?.emailAddress?.address ||\n  \"\";\n\nconst clinic = toAddress\n  ? toAddress.split(\".\")[0].trim().toUpperCase()\n  : null;\n\n// -----------------------------\n// Helpers\n// -----------------------------\nfunction decodeHtml(value) {\n  return String(value || \"\")\n    .replace(/&nbsp;/gi, \" \")\n    .replace(/&amp;/gi, \"&\")\n    .replace(/&quot;/gi, '\"')\n    .replace(/&#39;/gi, \"'\")\n    .replace(/&lt;/gi, \"<\")\n    .replace(/&gt;/gi, \">\");\n}\n\nfunction htmlToText(value) {\n  return decodeHtml(value)\n    .replace(/<style[\\s\\S]*?<\\/style>/gi, \" \")\n    .replace(/<script[\\s\\S]*?<\\/script>/gi, \" \")\n    .replace(/<[^>]+>/g, \" \")\n    .replace(/[\\u200B-\\u200D\\uFEFF\\u200A\\u202F]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n}\n\nfunction safeDecodeUrl(value) {\n  try {\n    return decodeURIComponent(value);\n  } catch (error) {\n    return value;\n  }\n}\n\nfunction extractScriptUrl(value) {\n  const raw = String(value || \"\");\n\n  // Direct clean Ausscripts URL\n  let match = raw.match(/https:\\/\\/ausscripts\\.erx\\.com\\.au\\/scripts\\/[A-Z0-9]+/i);\n  if (match) return match[0];\n\n  // Proofpoint URLDefense wrapped URL\n  const proofpointMatch = raw.match(/https:\\/\\/urldefense\\.com\\/v3\\/__([^;]+)__/i);\n  if (proofpointMatch) {\n    const innerUrl = safeDecodeUrl(proofpointMatch[1]);\n\n    match = innerUrl.match(/https:\\/\\/ausscripts\\.erx\\.com\\.au\\/scripts\\/[A-Z0-9]+/i);\n    if (match) return match[0];\n  }\n\n  // Fallback after HTML entity decode\n  const decodedHtml = decodeHtml(raw);\n  match = decodedHtml.match(/https:\\/\\/ausscripts\\.erx\\.com\\.au\\/scripts\\/[A-Z0-9]+/i);\n  if (match) return match[0];\n\n  return null;\n}\n\n// -----------------------------\n// Extract script details\n// -----------------------------\nconst text = htmlToText(html);\nconst scriptUrl = extractScriptUrl(html);\nconst scriptId = scriptUrl ? scriptUrl.split(\"/\").pop() : null;\n\n// Example text:\n// Tap the link to view BV's ePrescription for 5% Minoxidil + 0.25% Finasteride Lotion lotion ...\nconst prescriptionMatch = text.match(\n  /Tap the link to view\\s+(.+?)'s ePrescription for\\s+(.+?)(?:\\s+https:\\/\\/ausscripts\\.erx\\.com\\.au\\/scripts\\/| Have a question|$)/i\n);\n\nconst patientInitials = prescriptionMatch?.[1]?.trim() || null;\n\nlet productName = prescriptionMatch?.[2]?.trim() || null;\n\nif (productName) {\n  productName = productName\n    .replace(/\\s+/g, \" \")\n    .replace(/\\s+lotion\\s+/i, \" Lotion \")\n    .replace(/(Lotion)\\s+\\1/gi, \"$1\")\n    .trim();\n\n  // Fix duplicated product format from this email template\n  const words = productName.split(\" \");\n  const midpoint = Math.floor(words.length / 2);\n\n  const firstHalf = words.slice(0, midpoint).join(\" \").trim();\n  const secondHalf = words.slice(midpoint).join(\" \").trim();\n\n  if (\n    firstHalf &&\n    secondHalf &&\n    firstHalf.toLowerCase() === secondHalf.toLowerCase()\n  ) {\n    productName = firstHalf;\n  }\n\n  // Specific cleanup for duplicated \"Lotion product again\" style\n  const duplicateProductMatch = productName.match(/^(.+?Lotion)\\s+\\1$/i);\n  if (duplicateProductMatch) {\n    productName = duplicateProductMatch[1];\n  }\n}\n\n// -----------------------------\n// Date and folder names\n// -----------------------------\nconst receivedDate = input.receivedDateTime\n  ? new Date(input.receivedDateTime).toISOString().slice(0, 10)\n  : new Date().toISOString().slice(0, 10);\n\nconst dateFolderName = receivedDate;\nconst clinicFolderName = clinic || \"UNKNOWNCLINIC\";\n\nconst safePatientInitials = patientInitials || \"UnknownInitials\";\nconst safeScriptId = scriptId || \"UnknownScript\";\nconst fileName = `${receivedDate}-${safeScriptId}-${safePatientInitials}.pdf`;\n\n// -----------------------------\n// SharePoint / Graph IDs\n// -----------------------------\nconst DriveID = \"b!keZy0EVJt0ydRozgmmR1eQMBvSWtB5hGktxakZsBcZvoqANme--qSo6QvDZ3hdgU\";\n\nconst AUMedOrderID = \"01Y4DA4OPCXITTGW45PJHZBMOQ2WVAPCD2\";\n\nconst CompletedOrdersID = \"01Y4DA4OMCIC7MC3JRSBG2QB4JYEGHALNK\";\n\n// Correct folder ID for:\n// -=AU Med Orders=- / OrderInProgress\nconst OrderInProgressID = \"01Y4DA4OMQFXPAO6YE25F2FTI3HY3VF4HL\";\n\n// -----------------------------\n// Final output\n// -----------------------------\nreturn {\n  json: {\n    isPrescriptionEmail: !!scriptUrl,\n\n    emailId,\n    originalMessageId: emailId,\n\n    clinic,\n    clinicFolderName,\n\n    patientInitials,\n    productName,\n\n    scriptUrl,\n    scriptId,\n\n    receivedDate,\n    dateFolderName,\n\n    fileName,\n\n    DriveID,\n    AUMedOrderID,\n    CompletedOrdersID,\n    OrderInProgressID,\n  },\n};"
        },
