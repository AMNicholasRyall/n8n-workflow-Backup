      },
      {
        "parameters": {
          "toRecipients": "=AM-CC-Staff@ashleyandmartin.com.au",
          "subject": "=Automation - New Opportunities",
          "bodyContent": "=<div style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333333; line-height: 1.5;\">\n\n  <p>Hi Team,</p>\n\n  <p>\n    Please see below for the recent Zenoti opportunities.\n  </p>\n\n  <div style=\"margin-top: 12px; margin-bottom: 18px;\">\n    {{ $json.htmlTable }}\n  </div>\n\n  <p>\n    Regards,<br>\n    Automation\n  </p>\n\n</div>",
