        "name": "Filter1"
      },
      {
        "parameters": {
          "jsCode": "return $input.all().map(item => {\n  item.json.directlink = `https://ashleymartinau.zenoti.com/Admin/Sales/OpportunityCreate.aspx?OpportunityId=${item.json.opportunity_id}`;\n  return item;\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          960,
          -256
        ],
        "id": "ce614dd8-284b-4ce4-96fd-13b555bc50b4",
        "name": "CreateDirctLink"
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\n\nconst escapeHtml = (value) => {\n  if (value === null || value === undefined) return \"\";\n  return String(value)\n    .replaceAll(\"&\", \"&amp;\")\n    .replaceAll(\"<\", \"&lt;\")\n    .replaceAll(\">\", \"&gt;\")\n    .replaceAll('\"', \"&quot;\")\n    .replaceAll(\"'\", \"&#039;\");\n};\n\nconst rows = items.map(item => {\n  const data = item.json;\n\n  const centerName = data.center_name;\n  const guestName = data.guest?.guest_name;\n  const guestCode = data.guest?.guest_code;\n  const directLink = data.directlink;\n\n  return `\n    <tr>\n      <td>${escapeHtml(centerName)}</td>\n      <td>${escapeHtml(guestName)}</td>\n      <td>${escapeHtml(guestCode)}</td>\n      <td><a href=\"${escapeHtml(directLink)}\">Open Opportunity</a></td>\n    </tr>\n  `;\n}).join(\"\");\n\nconst htmlTable = `\n<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\" style=\"border-collapse: collapse; font-family: Arial, sans-serif; font-size: 13px;\">\n  <thead>\n    <tr style=\"background-color: #f2f2f2;\">\n      <th>Center</th>\n      <th>Guest Name</th>\n      <th>Guest Code</th>\n      <th>Link</th>\n    </tr>\n  </thead>\n  <tbody>\n    ${rows}\n  </tbody>\n</table>\n`;\n\nreturn [\n  {\n    json: {\n      htmlTable,\n      recordCount: items.length\n    }\n  }\n];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
