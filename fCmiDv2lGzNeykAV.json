        "jsCode": "return items.map(item => {\n  const timeZoneText = item.json.time_zone;\n\n  // Example input:\n  // \"(UTC+09:30) Adelaide\"\n  // \"(UTC+10:00) Brisbane\"\n  const match = timeZoneText.match(/UTC([+-])(\\d{2}):(\\d{2})/);\n\n  if (!match) {\n    throw new Error(`Could not read timezone from: ${timeZoneText}`);\n  }\n\n  const sign = match[1] === \"+\" ? 1 : -1;\n  const hours = parseInt(match[2], 10);\n  const minutes = parseInt(match[3], 10);\n\n  const offsetMinutes = sign * ((hours * 60) + minutes);\n\n  const clinicTimeMinus15 = $now\n    .toUTC()\n    .plus({ minutes: offsetMinutes })\n    .minus({ minutes: 15 })\n    .toFormat(\"yyyy-MM-dd'T'HH:mm:ss\");\n\n  item.json.clinic_time_minus_15 = clinicTimeMinus15;\n\n  return item;\n});"
      },
