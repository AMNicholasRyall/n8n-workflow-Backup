        "jsCode": "return $input.all().map(item => {\n  item.json.directlink = `https://ashleymartinau.zenoti.com/Admin/Sales/OpportunityCreate.aspx?OpportunityId=${item.json.opportunity_id}`;\n  return item;\n});"
